@* Renders an ExclusionsResponse. *@

@if (Exclusions is null)
{
    <p class="text-muted"><em>No exclusions loaded yet.</em></p>
}
else if (Exclusions.Exclusions.Count == 0)
{
    <p class="text-muted"><em>No exclusions for this user.</em></p>
}
else
{
    <table class="table table-sm exclusions">
        <thead>
            <tr><th>Type</th><th>From</th><th>To</th></tr>
        </thead>
        <tbody>
            @foreach (var x in Exclusions.Exclusions)
            {
                <tr>
                    <td><span class="excl-type">@x.TypeExclusion</span></td>
                    <td>@x.StartDatetime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@x.EndDatetime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public ExclusionsResponse? Exclusions { get; set; }
}
