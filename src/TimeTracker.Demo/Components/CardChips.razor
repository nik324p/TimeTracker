@* Renders a CardListResponse's card_uids as chips. *@

@if (Cards is null)
{
    <p class="text-muted"><em>No cards loaded yet.</em></p>
}
else if (Cards.Cards.Count == 0)
{
    <p class="text-muted"><em>User @Cards.UserId has no cards.</em></p>
}
else
{
    <div class="card-chips">
        @foreach (var uid in Cards.Cards)
        {
            <span class="uid-chip">@uid</span>
        }
    </div>
}

@code {
    [Parameter] public CardListResponse? Cards { get; set; }
}
