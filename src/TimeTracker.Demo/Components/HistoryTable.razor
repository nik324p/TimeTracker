@* Renders a HistoryResponse. ShowUser toggles a leading user_id column (on for all-workers feed). *@

@if (History is null)
{
    <p class="text-muted"><em>No history loaded yet.</em></p>
}
else if (History.Entries.Count == 0)
{
    <p class="text-muted"><em>History is empty.</em></p>
}
else
{
    <table class="table table-sm history">
        <thead>
            <tr>
                @if (ShowUser) { <th>User</th> }
                <th>Date</th>
                <th>Arrival</th>
                <th>Departure</th>
                <th>Worked</th>
                <th>Late?</th>
                <th>Left early?</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in History.Entries)
            {
                <tr>
                    @if (ShowUser) { <td>@e.UserId</td> }
                    <td>@e.Date.ToString("yyyy-MM-dd")</td>
                    <td>@Format.Time(e.Arrival)</td>
                    <td>@Format.Time(e.Departure)</td>
                    <td>@Format.Hours(e.WorkedMinutes)</td>
                    <td>@FlagPill(e.WasLate, e.LateExcused, "late")</td>
                    <td>@FlagPill(e.LeftEarly, e.LeftEarlyExcused, "early")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public HistoryResponse? History { get; set; }
    [Parameter] public bool ShowUser { get; set; }

    private static RenderFragment FlagPill(bool flagged, bool excused, string word) => builder =>
    {
        var (css, text) = !flagged
            ? ("flag flag-ok", "on time")
            : excused ? ("flag flag-warn", $"{word} · excused") : ("flag flag-bad", word);
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", css);
        builder.AddContent(2, text);
        builder.CloseElement();
    };
}
